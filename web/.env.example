# Copy to web/.env.local and fill in values. Never commit .env.local.
# For Vercel, set the same names in Project → Settings → Environment Variables.

# --- Clerk (https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk routes (safe defaults for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Supabase (project settings → API; browser-safe publishable key only) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Analysis API (server-only; used by /api/analyze route handler) ---
# Vercel → Render. Do not use NEXT_PUBLIC_ for these.
ANALYSIS_API_URL=http://127.0.0.1:8000
# Same value on Vercel and Render when hosted validation is enabled.
ANALYSIS_API_SHARED_SECRET=

# --- Smart AI (server-only; optional beta feature) ---
# Must be exactly "true" to enable Smart AI routes and UI default.
AI_FEATURES_ENABLED=
# Vercel server-side quota limits (signed-in users)
AI_DAILY_LIMIT=10
AI_MONTHLY_LIMIT=50
AI_PROFILE_MONTHLY_LIMIT=10
# Comma-separated Clerk user IDs that bypass Smart AI quota limits (owner/admin testing only).
# Server-only — do not use NEXT_PUBLIC_*. Normal users remain limited.
# AI_QUOTA_BYPASS_USER_IDS=user_3FuilgIMls6NHMejlNAYDv6SATc

# --- Quota alert email (server-only; optional) ---
# Resend API key — never use NEXT_PUBLIC_* for email credentials.
RESEND_API_KEY=
AI_QUOTA_ALERT_EMAIL=
ALERTS_FROM_EMAIL=

# --- Tip jar nudge (optional; client-visible URL only) ---
# Hidden when NEXT_PUBLIC_TIP_JAR_URL is unset. Does not affect analysis or quotas.
NEXT_PUBLIC_TIP_JAR_URL=
NEXT_PUBLIC_TIP_PROMPT_ANALYSIS_THRESHOLD=5

# Render / FastAPI only (never expose in browser or NEXT_PUBLIC_*)
# OPENAI_API_KEY=
# OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
# OPENAI_REQUEST_TIMEOUT_SECONDS=30

# Legacy (optional fallback in code only; do not set on Vercel unless migrating):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
