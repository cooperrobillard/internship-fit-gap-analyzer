    "qa:version23:report": "echo \"Report is generated by the Playwright global teardown at /tmp/version23-data-control-qa.md\"",
    "qa:version23:cleanup:dry-run": "playwright test --config=playwright.config.ts --global-timeout=1 --grep \"^$\" || true",
    "qa:version23:cleanup": "playwright test --config=playwright.config.ts --global-timeout=1 --grep \"^$\" || true"
